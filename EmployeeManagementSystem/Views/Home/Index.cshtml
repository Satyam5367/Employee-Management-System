@model EmployeeManagementSystem.ViewModels.DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary mb-0"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a asp-controller="Employee" asp-action="Create" class="btn btn-primary">
            <i class="fas fa-user-plus me-1"></i>Add Employee
        </a>
    }
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="fas fa-users fa-2x text-primary"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Employees</div>
                    <div class="fs-2 fw-bold">@Model.TotalEmployees</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="fas fa-user-check fa-2x text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">Active</div>
                    <div class="fs-2 fw-bold text-success">@Model.ActiveEmployees</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                    <i class="fas fa-user-times fa-2x text-danger"></i>
                </div>
                <div>
                    <div class="text-muted small">Inactive</div>
                    <div class="fs-2 fw-bold text-danger">@Model.InactiveEmployees</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="fas fa-rupee-sign fa-2x text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">Monthly Budget</div>
                    <div class="fs-4 fw-bold">₹@Model.TotalSalaryBudget.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Department Breakdown -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-semibold mb-0"><i class="fas fa-chart-pie me-2 text-primary"></i>By Department</h5>
            </div>
            <div class="card-body">
                <canvas id="deptChart" height="220"></canvas>
            </div>
        </div>
    </div>

    <!-- Recent Hires -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between">
                <h5 class="fw-semibold mb-0"><i class="fas fa-clock me-2 text-primary"></i>Recent Hires</h5>
                <a asp-controller="Employee" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4">Name</th>
                                <th>Department</th>
                                <th>Title</th>
                                <th>Joined</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model.RecentHires)
                            {
                                <tr>
                                    <td class="px-4">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar-circle bg-primary text-white">
                                                @emp.FirstName[0]@emp.LastName[0]
                                            </div>
                                            <span class="fw-medium">@emp.FullName</span>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-light text-dark">@emp.Department</span></td>
                                    <td class="text-muted small">@emp.JobTitle</td>
                                    <td class="text-muted small">@emp.DateOfJoining.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (emp.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger">Inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EmployeesByDepartment.Keys));
    const data   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EmployeesByDepartment.Values));
    const colors = ['#0d6efd','#198754','#dc3545','#ffc107','#0dcaf0','#6f42c1','#fd7e14'];
    new Chart(document.getElementById('deptChart'), {
        type: 'doughnut',
        data: { labels, datasets: [{ data, backgroundColor: colors, borderWidth: 2 }] },
        options: {
            responsive: true,
            plugins: { legend: { position: 'bottom' } }
        }
    });
</script>
}
