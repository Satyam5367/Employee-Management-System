@model EmployeeManagementSystem.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Register"; Layout = null; }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register – EMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-light">

<div class="min-vh-100 d-flex align-items-center justify-content-center py-4">
    <div class="w-100" style="max-width:460px">

        <div class="text-center mb-4">
            <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center mb-3"
                 style="width:64px;height:64px">
                <i class="fas fa-user-plus text-white fa-2x"></i>
            </div>
            <h3 class="fw-bold">Create Account</h3>
            <p class="text-muted">EMS Portal Registration</p>
        </div>

        <div class="card border-0 shadow">
            <div class="card-body p-4">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-medium"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user text-muted"></i></span>
                            <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-medium"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="you@company.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-medium">Role</label>
                        <select asp-for="Role" class="form-select">
                            <option value="Employee">Employee</option>
                            <option value="Manager">Manager</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-medium"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="Min 6 chars, 1 uppercase, 1 symbol" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-medium"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-medium">
                        <i class="fas fa-user-plus me-2"></i>Create Account
                    </button>
                </form>
            </div>
        </div>

        <p class="text-center text-muted small mt-3">
            Already have an account?
            <a asp-action="Login" class="text-decoration-none">Sign in</a>
        </p>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />
</body>
</html>
