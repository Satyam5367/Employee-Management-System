@model EmployeeManagementSystem.ViewModels.EmployeeListViewModel
@{ ViewData["Title"] = "Employees"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary mb-0"><i class="fas fa-users me-2"></i>Employees
        <span class="badge bg-primary ms-2 fs-6">@Model.TotalCount</span>
    </h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-user-plus me-1"></i>Add Employee
        </a>
    }
</div>

<!-- Search & Filter Bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" name="search" value="@Model.SearchTerm"
                           class="form-control" placeholder="Name, email, title..." />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted">Department</label>
                <select name="department" class="form-select">
                    <option value="">All Departments</option>
                    @foreach (var dept in Model.Departments)
                    {
                        <option value="@dept" @(Model.DepartmentFilter == dept ? "selected" : "")>@dept</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">Status</label>
                <select name="status" class="form-select">
                    <option value="">All</option>
                    <option value="active"   @(Model.StatusFilter == "active"   ? "selected" : "")>Active</option>
                    <option value="inactive" @(Model.StatusFilter == "inactive" ? "selected" : "")>Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">Per Page</label>
                <select name="pageSize" class="form-select">
                    @foreach (var s in new[] { 5, 10, 25 })
                    {
                        <option value="@s" @(Model.PageSize == s ? "selected" : "")>@s</option>
                    }
                </select>
            </div>
            <div class="col-md-1 d-flex gap-1">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="fas fa-times"></i></a>
            </div>
            <input type="hidden" name="sortBy"    value="@Model.SortBy" />
            <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Employees.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
                <p class="fs-5">No employees found.</p>
                <a asp-action="Index" class="btn btn-outline-primary">Clear Filters</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4">
                                @{ string nameOrder = Model.SortBy == "Name" && Model.SortOrder == "asc" ? "desc" : "asc"; }
                                <a asp-action="Index" asp-route-sortBy="Name" asp-route-sortOrder="@nameOrder"
                                   asp-route-search="@Model.SearchTerm" asp-route-department="@Model.DepartmentFilter"
                                   asp-route-status="@Model.StatusFilter" asp-route-pageSize="@Model.PageSize"
                                   class="text-dark text-decoration-none">
                                    Name <i class="fas fa-sort @(Model.SortBy == "Name" ? "text-primary" : "text-muted")"></i>
                                </a>
                            </th>
                            <th>
                                @{ string deptOrder = Model.SortBy == "Department" && Model.SortOrder == "asc" ? "desc" : "asc"; }
                                <a asp-action="Index" asp-route-sortBy="Department" asp-route-sortOrder="@deptOrder"
                                   asp-route-search="@Model.SearchTerm" asp-route-department="@Model.DepartmentFilter"
                                   asp-route-status="@Model.StatusFilter" asp-route-pageSize="@Model.PageSize"
                                   class="text-dark text-decoration-none">
                                    Department <i class="fas fa-sort @(Model.SortBy == "Department" ? "text-primary" : "text-muted")"></i>
                                </a>
                            </th>
                            <th>Job Title</th>
                            <th>
                                @{ string salOrder = Model.SortBy == "Salary" && Model.SortOrder == "asc" ? "desc" : "asc"; }
                                <a asp-action="Index" asp-route-sortBy="Salary" asp-route-sortOrder="@salOrder"
                                   asp-route-search="@Model.SearchTerm" asp-route-department="@Model.DepartmentFilter"
                                   asp-route-status="@Model.StatusFilter" asp-route-pageSize="@Model.PageSize"
                                   class="text-dark text-decoration-none">
                                    Salary <i class="fas fa-sort @(Model.SortBy == "Salary" ? "text-primary" : "text-muted")"></i>
                                </a>
                            </th>
                            <th>
                                @{ string joinOrder = Model.SortBy == "Joining" && Model.SortOrder == "asc" ? "desc" : "asc"; }
                                <a asp-action="Index" asp-route-sortBy="Joining" asp-route-sortOrder="@joinOrder"
                                   asp-route-search="@Model.SearchTerm" asp-route-department="@Model.DepartmentFilter"
                                   asp-route-status="@Model.StatusFilter" asp-route-pageSize="@Model.PageSize"
                                   class="text-dark text-decoration-none">
                                    Joined <i class="fas fa-sort @(Model.SortBy == "Joining" ? "text-primary" : "text-muted")"></i>
                                </a>
                            </th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in Model.Employees)
                        {
                            <tr>
                                <td class="px-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-circle bg-primary text-white">
                                            @emp.FirstName[0]@emp.LastName[0]
                                        </div>
                                        <div>
                                            <div class="fw-medium">@emp.FullName</div>
                                            <div class="text-muted small">@emp.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge bg-light text-dark">@emp.Department</span></td>
                                <td class="text-muted">@emp.JobTitle</td>
                                <td class="fw-medium">₹@emp.Salary.ToString("N0")</td>
                                <td class="text-muted small">@emp.DateOfJoining.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (emp.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <a asp-action="Details" asp-route-id="@emp.Id"
                                           class="btn btn-sm btn-outline-info" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@emp.Id"
                                               class="btn btn-sm btn-outline-primary" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form asp-action="ToggleStatus" asp-route-id="@emp.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm @(emp.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                        title="@(emp.IsActive ? "Deactivate" : "Activate")">
                                                    <i class="fas @(emp.IsActive ? "fa-ban" : "fa-check")"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@emp.Id"
                                               class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top">
                    <small class="text-muted">
                        Showing @((Model.CurrentPage - 1) * Model.PageSize + 1)–@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount))
                        of @Model.TotalCount employees
                    </small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage - 1)"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-department="@Model.DepartmentFilter"
                                   asp-route-status="@Model.StatusFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-pageSize="@Model.PageSize">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = Math.Max(1, Model.CurrentPage - 2);
                                      i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-search="@Model.SearchTerm"
                                       asp-route-department="@Model.DepartmentFilter"
                                       asp-route-status="@Model.StatusFilter"
                                       asp-route-sortBy="@Model.SortBy"
                                       asp-route-sortOrder="@Model.SortOrder"
                                       asp-route-pageSize="@Model.PageSize">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage + 1)"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-department="@Model.DepartmentFilter"
                                   asp-route-status="@Model.StatusFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-pageSize="@Model.PageSize">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>
