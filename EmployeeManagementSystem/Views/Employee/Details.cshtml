@model EmployeeManagementSystem.Models.Employee
@{ ViewData["Title"] = "Employee Details"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary mb-0"><i class="fas fa-id-card me-2"></i>Employee Profile</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4">
            <div class="avatar-circle-lg bg-primary text-white mx-auto mb-3">
                @Model.FirstName[0]@Model.LastName[0]
            </div>
            <h4 class="fw-bold mb-1">@Model.FullName</h4>
            <p class="text-muted mb-2">@Model.JobTitle</p>
            <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger") fs-6 mb-3">
                @(Model.IsActive ? "Active" : "Inactive")
            </span>
            <div class="d-flex gap-2 justify-content-center mt-2">
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                        <i class="fas fa-edit me-1"></i>Edit
                    </a>
                    <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm @(Model.IsActive ? "btn-warning" : "btn-success")">
                            <i class="fas @(Model.IsActive ? "fa-ban" : "fa-check") me-1"></i>
                            @(Model.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash me-1"></i>Delete
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4">
                <h5 class="fw-semibold"><i class="fas fa-info-circle me-2 text-primary"></i>Employee Details</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="detail-item">
                            <span class="text-muted small d-block"><i class="fas fa-envelope me-1"></i>Email</span>
                            <strong>@Model.Email</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <span class="text-muted small d-block"><i class="fas fa-phone me-1"></i>Phone</span>
                            <strong>@Model.Phone</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <span class="text-muted small d-block"><i class="fas fa-building me-1"></i>Department</span>
                            <span class="badge bg-light text-dark fs-6">@Model.Department</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <span class="text-muted small d-block"><i class="fas fa-briefcase me-1"></i>Job Title</span>
                            <strong>@Model.JobTitle</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <span class="text-muted small d-block"><i class="fas fa-calendar me-1"></i>Date of Joining</span>
                            <strong>@Model.DateOfJoining.ToString("dd MMMM yyyy")</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <span class="text-muted small d-block"><i class="fas fa-rupee-sign me-1"></i>Salary</span>
                            <strong class="text-success fs-5">₹@Model.Salary.ToString("N0")</strong>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <div class="col-12">
                            <div class="detail-item">
                                <span class="text-muted small d-block"><i class="fas fa-map-marker-alt me-1"></i>Address</span>
                                <strong>@Model.Address</strong>
                            </div>
                        </div>
                    }
                    <div class="col-md-6">
                        <div class="detail-item">
                            <span class="text-muted small d-block"><i class="fas fa-clock me-1"></i>Record Created</span>
                            <strong>@Model.CreatedAt.ToString("dd MMM yyyy")</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <span class="text-muted small d-block"><i class="fas fa-sync me-1"></i>Last Updated</span>
                            <strong>@Model.UpdatedAt.ToString("dd MMM yyyy")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
